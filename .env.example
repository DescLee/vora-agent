# LLM provider: mock | openai-compatible
LLM_PROVIDER=mock

# OpenAI-compatible chat completions endpoint base URL
# Example: http://localhost:1234/v1
LLM_BASE_URL=

# API key for the configured endpoint
LLM_API_KEY=

# Model name sent in the request payload
LLM_MODEL=gpt-4o-mini

# Request timeout in seconds
LLM_TIMEOUT_SECONDS=120
LLM_MAX_ATTEMPTS=3
LLM_RETRY_BACKOFF_SECONDS=0.25
